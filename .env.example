# Server
DATAVAULT_APP_PORT=8080   # port inside container / direct run
DATAVAULT_ENV=dev         # dev | test | prod (stub HSM is blocked when prod)
HOST_PORT=8081            # Docker host port mapping only — not an app variable

# Database driver: postgres | mssql | oracle
DATAVAULT_DB_DRIVER=postgres
DATAVAULT_DB_DSN=postgres://user:pass@localhost:5432/datavault?sslmode=disable

# MSSQL (used when DATAVAULT_DB_DRIVER=mssql)
DATAVAULT_MSSQL_HOST=localhost
DATAVAULT_MSSQL_PORT=1433
DATAVAULT_MSSQL_USER=sa
DATAVAULT_MSSQL_PASS=secret
DATAVAULT_MSSQL_DB=datavault

# Oracle (used when DATAVAULT_DB_DRIVER=oracle)
DATAVAULT_ORACLE_DSN=localhost:1521/XEPDB1
DATAVAULT_ORACLE_USER=datavault
DATAVAULT_ORACLE_PASS=secret

# HSM / Key Management
# DATAVAULT_HSM_MODE=stub    — in-process software HSM (dev/test only)
# DATAVAULT_HSM_MODE=certex  — CERTEX HSM ES REST adapter
# DATAVAULT_HSM_MODE=pkcs11  — production PKCS#11 HSM (not yet implemented)
# NOTE: stub mode is BLOCKED when DATAVAULT_ENV=prod
DATAVAULT_HSM_MODE=stub
# CERTEX HSM ES REST connection (required when DATAVAULT_HSM_MODE=certex):
# DATAVAULT_HSM_URL=https://10.0.0.1:8443
# DATAVAULT_HSM_USER=admin          # Basic-auth username — never commit real values
# DATAVAULT_HSM_PASS=secret         # Basic-auth password — never commit real values
# PKCS#11 library path and slot configuration (required for pkcs11 mode):
# PKCS11_LIB=/usr/lib/softhsm/libsofthsm2.so
# PKCS11_SLOT=0
# PKCS11_PIN=<your-hsm-pin>  # never commit real PINs to VCS

# Search key (hex-encoded 32 bytes) — used for HMAC-SHA256 search tokens, never log
DATAVAULT_SEARCH_KEY=replace_with_64_hex_chars

# API key for bearer token authentication — never log, never commit real values
# Clients must send: Authorization: Bearer <value>
DATAVAULT_API_KEY=replace_with_strong_random_secret

# DEK cache TTL (e.g. 5m, 30s)
DATAVAULT_DEK_CACHE_TTL=5m

# Database connection pool (applied to all drivers)
# Defaults: max=20, min=2, lifetime=30m, idle=5m, health-check=1m (pgx only)
DATAVAULT_DB_MAX_CONNS=20
DATAVAULT_DB_MIN_CONNS=2
DATAVAULT_DB_CONN_MAX_LIFETIME=30m
DATAVAULT_DB_CONN_MAX_IDLE_TIME=5m
DATAVAULT_DB_HEALTH_CHECK_PERIOD=1m  # PostgreSQL only (pgx HealthCheckPeriod)

# Log level: debug | info | warn | error
DATAVAULT_LOG_LEVEL=info

# PostgreSQL credentials (used by docker-compose postgres service)
POSTGRES_USER=datavault
POSTGRES_PASSWORD=secret
POSTGRES_DB=datavault
